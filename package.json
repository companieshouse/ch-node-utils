{
  "name": "@companieshouse/ch-node-utils",
  "version": "2.1.0",
  "author": "companieshouse",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "lib",
    "templates",
    "locales"
  ],
  "description": "set of node utils which can be used across repos/projects",
  "repository": {
    "type": "git",
    "url": "https://github.com/companieshouse/ch-node-utils"
  },
  "scripts": {
    "prebuild": "rm -rf ./lib",
    "build": "tsc",
    "test": "jest",
    "lint": "eslint '{src,test}/**/*'",
    "lint:fix": "eslint '{src,test}/**/*' --fix",
    "coverage": "jest --coverage --forceExit --passWithNoTests",
    "prepublishOnly": "[ ! -d node_modules ] && npm install; tsc",
    "postpublish": "rm -rf lib"
  },
  "license": "MIT",
  "dependencies": {
    "@companieshouse/node-session-handler": "^5.2.10",
    "express": "^4.22.1",
    "i18next": "^23.16.8",
    "i18next-fs-backend": "^2.6.3",
    "ioredis": "^5.10.1",
    "iso-639-1": "^3.1.5",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/core": "^1.15.21",
    "@swc/jest": "^0.2.39",
    "@types/express": "^4.17.25",
    "@types/i18next": "^13.0.0",
    "@types/ioredis": "4.28.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "govuk-frontend-6-0-0": "npm:govuk-frontend@6.1.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "nunjucks": "^3.2.4",
    "typescript": "^5.9.3"
  },
  "overrides": {
      "glob": "12.0.0"
  },
  "peerDependencies": {
    "govuk-frontend": "^6.0.0"
  },
  "bugs": {
